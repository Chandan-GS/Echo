# Force GitHub Linguist to ignore all HTML files completely
*.html linguist-detectable=false
*.html linguist-vendored

# Mark all platform directories as vendored to exclude boilerplates (C++, Kotlin, Swift, CMake)
web/** linguist-vendored
android/** linguist-vendored
ios/** linguist-vendored
macos/** linguist-vendored
windows/** linguist-vendored
linux/** linguist-vendored
